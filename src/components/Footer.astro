---
const año = new Date().getFullYear();

const links = [
  { label: "Pescadores", href: "/pescadores" },
  { label: "Clasificaciones", href: "/clasificaciones" },
  { label: "Eventos", href: "/eventos" },
  { label: "Contacto", href: "/contacto" },
  { label: "Privacidad", href: "/privacidad" },
  { label: "Cookies", href: "/cookies" },
];
---

<footer
  class="border-t border-white/[0.07] bg-gradient-to-b from-sky-50 via-white to-blue-50 mt-auto"
>
  <div class="max-w-5xl mx-auto px-6 py-8">
    <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
      <!-- Logo / nombre -->
      <div class="flex items-center gap-2 text-black/80">
        <span class="text-2xl">🎣</span>
        <div>
          <p class="font-bold text-sm leading-tight">CDF-LAMORAÑA</p>
          <p class="text-xs text-black/35">Sociedad Deportiva de Pesca</p>
        </div>
      </div>

      <!-- Links -->
      <nav class="flex flex-wrap justify-center gap-x-5 gap-y-1">
        {
          links.map((l) => (
            <a
              href={l.href}
              class="text-xs text-black/40 hover:text-black/80 transition-colors"
            >
              {l.label}
            </a>
          ))
        }
      </nav>
    </div>

    <!-- Línea inferior -->
    <div
      class="mt-6 pt-4 border-t border-white/[0.05] text-center text-xs text-black/25 flex flex-col sm:flex-row items-center justify-center gap-2"
    >
      <span>© {año} CDF-LAMORAÑA · Todos los derechos reservados</span>
      <span class="hidden sm:inline" aria-hidden="true">·</span>
      <button
        type="button"
        onclick="window.openCookieBanner?.()"
        class="text-xs text-black/35 hover:text-black/70 transition-colors underline underline-offset-2 cursor-pointer"
      >
        Gestionar cookies
      </button>
    </div>
  </div>
</footer>
