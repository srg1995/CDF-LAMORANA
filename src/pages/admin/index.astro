---
import '../../styles/global.css';
---

<!doctype html>
<html lang="es" class="h-full">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Gestión — CDF-LAMORAÑA</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="h-full bg-slate-900 font-sans antialiased flex items-center justify-center px-4">

    <div id="content" class="hidden text-center">
      <h1 class="text-2xl font-extrabold text-white mb-2">Área de gestión</h1>
      <p class="text-slate-400 text-sm mb-8">Selecciona una sección para gestionar.</p>

      <nav class="flex flex-col items-center gap-3">
        <a
          href="/admin/jornadas"
          class="w-full max-w-xs bg-slate-800 hover:bg-slate-700 border border-slate-700 hover:border-slate-600 rounded-xl px-5 py-4 text-left transition group"
        >
          <p class="font-semibold text-white group-hover:text-sky-400 transition text-sm">🎣 Registro de jornadas</p>
          <p class="text-slate-400 text-xs mt-0.5">Selecciona pescadores y exporta a Excel</p>
        </a>
      </nav>

      <button
        id="logout-btn"
        class="mt-10 text-xs text-slate-500 hover:text-slate-300 underline transition"
      >
        Cerrar sesión
      </button>
    </div>

    <script>
      if (sessionStorage.getItem('adminAuth') !== 'true') {
        window.location.replace('/admin/login');
      } else {
        (document.getElementById('content') as HTMLDivElement).classList.remove('hidden');
      }

      document.getElementById('logout-btn')!.addEventListener('click', () => {
        sessionStorage.removeItem('adminAuth');
        window.location.href = '/admin/login';
      });
    </script>

  </body>
</html>
