---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout title="Contacto — CDF-LAMORAÑA" heading="Contacto" description="¿Tienes alguna pregunta? Escríbenos y te respondemos lo antes posible.">
    <section class="max-w-5xl mx-auto px-6 pt-8 pb-20 grid grid-cols-1 md:grid-cols-2 gap-10 items-start">

      <!-- Contact form -->
      <div class="bg-white rounded-2xl shadow-md border border-sky-100 p-8">
        <h2 class="text-xl font-bold text-slate-800 mb-6">Envíanos un mensaje</h2>
        <form class="space-y-5">
          <div>
            <label for="nombre" class="block text-sm font-medium text-slate-700 mb-1">Nombre</label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              placeholder="Tu nombre"
              class="w-full rounded-lg border border-slate-200 bg-slate-50 px-4 py-2.5 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent transition"
            />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700 mb-1">Correo electrónico</label>
            <input
              type="email"
              id="email"
              name="email"
              placeholder="tu@email.com"
              class="w-full rounded-lg border border-slate-200 bg-slate-50 px-4 py-2.5 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent transition"
            />
          </div>
          <div>
            <label for="asunto" class="block text-sm font-medium text-slate-700 mb-1">Asunto</label>
            <input
              type="text"
              id="asunto"
              name="asunto"
              placeholder="¿En qué podemos ayudarte?"
              class="w-full rounded-lg border border-slate-200 bg-slate-50 px-4 py-2.5 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent transition"
            />
          </div>
          <div>
            <label for="mensaje" class="block text-sm font-medium text-slate-700 mb-1">Mensaje</label>
            <textarea
              id="mensaje"
              name="mensaje"
              rows="5"
              placeholder="Escribe tu mensaje aquí..."
              class="w-full rounded-lg border border-slate-200 bg-slate-50 px-4 py-2.5 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent transition resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full bg-gradient-to-r from-sky-600 to-cyan-500 hover:from-sky-700 hover:to-cyan-600 text-white font-semibold py-3 rounded-lg transition-all shadow-sm hover:shadow-md"
          >
            Enviar mensaje
          </button>
        </form>
      </div>

      <!-- Info cards -->
      <div class="space-y-5">
        <div class="bg-white rounded-2xl shadow-md border border-sky-100 p-6 flex gap-4 items-start">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-sky-100 flex items-center justify-center text-sky-600 text-lg">
            📍
          </div>
          <div>
            <h3 class="font-semibold text-slate-800 mb-1">Ubicación</h3>
            <p class="text-slate-500 text-sm">La Moraña, Ávila, España</p>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-md border border-sky-100 p-6 flex gap-4 items-start">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-sky-100 flex items-center justify-center text-sky-600 text-lg">
            ✉️
          </div>
          <div>
            <h3 class="font-semibold text-slate-800 mb-1">Email</h3>
            <a href="mailto:info@cdf-lamorana.es" class="text-sky-600 hover:underline text-sm">
              info@cdf-lamorana.es
            </a>
          </div>
        </div>

        <div class="bg-white rounded-2xl shadow-md border border-sky-100 p-6 flex gap-4 items-start">
          <div class="flex-shrink-0 w-10 h-10 rounded-full bg-sky-100 flex items-center justify-center text-sky-600 text-lg">
            🕐
          </div>
          <div>
            <h3 class="font-semibold text-slate-800 mb-1">Horario de atención</h3>
            <p class="text-slate-500 text-sm">Lunes a viernes, 10:00 – 18:00</p>
          </div>
        </div>

        <div class="bg-gradient-to-br from-sky-600 to-cyan-500 rounded-2xl shadow-md p-6 text-white">
          <h3 class="font-bold text-lg mb-2">¿Quieres hacerte socio?</h3>
          <p class="text-sky-100 text-sm mb-4">
            Únete a la Sociedad Deportiva de Pesca CDF-LAMORAÑA y disfruta de todos nuestros eventos y servicios.
          </p>
          <a
            href="/sobre-nosotros"
            class="inline-block bg-white text-sky-700 font-semibold text-sm px-4 py-2 rounded-lg hover:bg-sky-50 transition"
          >
            Más información →
          </a>
        </div>
      </div>

    </section>
</PageLayout>
