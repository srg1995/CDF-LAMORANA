---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Contacto — CDF-LAMORAÑA">
  <main>
    <a href="/" class="back">← Volver</a>
    <h1>Contacto</h1>
    <p>
      Página de contacto. Edita este archivo en <code
        >src/pages/contacto.astro</code
      >.
    </p>
  </main>
</Layout>

<style>
  main {
    max-width: 800px;
    margin: 4rem auto;
    padding: 0 1.5rem;
    color: white;
    font-family: system-ui, sans-serif;
  }
  h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }
  .back {
    color: #a78bfa;
    text-decoration: none;
    font-size: 0.95rem;
  }
  .back:hover {
    text-decoration: underline;
  }
  code {
    background: rgba(255, 255, 255, 0.1);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-size: 0.85em;
  }
</style>
