---
import Layout from '../layouts/Layout.astro';
import BentoGrid from '../components/BentoGrid.astro';
---

<Layout title="CDF-LAMORAÑA">
  <main class="min-h-screen bg-[#0f1117]">
    <header class="text-center pt-12 pb-4 px-6">
      <h1 class="text-5xl font-extrabold tracking-tight bg-gradient-to-r from-blue-400 via-purple-400 to-white bg-clip-text text-transparent mb-2">
        CDF-LAMORAÑA
      </h1>
      <p class="text-white/40 text-lg">Sociedad Deportiva de Pesca</p>
    </header>
    <BentoGrid />
  </main>
</Layout>
