---
import PageLayout from '../layouts/PageLayout.astro';

type TipoEvento = 'pesca' | 'limpieza' | 'montaje' | 'reunion' | 'formacion';

interface Evento {
  id: number;
  titulo: string;
  tipo: TipoEvento;
  fecha: string;
  hora: string;
  lugar: string;
  descripcion: string;
  plazas: number | null;
  inscripcion: boolean;
}

const eventos: Evento[] = [
  {
    id: 1,
    titulo: 'Día de Pesca en el Río Lamoraña',
    tipo: 'pesca',
    fecha: '2025-04-20',
    hora: '07:00',
    lugar: 'Tramo Norte — Río Lamoraña',
    descripcion: 'Jornada de pesca libre para todos los socios. Se realizará suelta de piezas al finalizar el día. Recordad traer el permiso de pesca en vigor.',
    plazas: 20,
    inscripcion: true,
  },
  {
    id: 2,
    titulo: 'Jornada de Limpieza del Río',
    tipo: 'limpieza',
    fecha: '2025-04-27',
    hora: '09:00',
    lugar: 'Ribera del Río Lamoraña — Km 3 al Km 7',
    descripcion: 'Recogida de residuos en las orillas del río. La sociedad facilita guantes, bolsas y herramientas. Actividad abierta a familiares y no socios.',
    plazas: null,
    inscripcion: false,
  },
  {
    id: 3,
    titulo: 'Montaje de Pasos y Señalética',
    tipo: 'montaje',
    fecha: '2025-05-10',
    hora: '08:30',
    lugar: 'Accesos al coto — Puntos A, B y C',
    descripcion: 'Instalación de nuevos pasos de madera y señales informativas en los accesos al coto. Se necesitan voluntarios con vehículo.',
    plazas: 8,
    inscripcion: true,
  },
  {
    id: 4,
    titulo: 'Jornada de Pesca de Carpas',
    tipo: 'pesca',
    fecha: '2025-05-17',
    hora: '06:00',
    lugar: 'Pantano de Valdepeñas',
    descripcion: 'Jornada especial de carpfishing de 24 horas. Modalidad captura y suelta. Habrá trofeo para el mayor ejemplar.',
    plazas: 14,
    inscripcion: true,
  },
  {
    id: 5,
    titulo: 'Reunión General de Socios',
    tipo: 'reunion',
    fecha: '2025-06-05',
    hora: '19:30',
    lugar: 'Casa de la Cultura — Salón Principal',
    descripcion: 'Asamblea ordinaria anual. Aprobación de cuentas, elección de cargos y presentación del plan de actividades del segundo semestre.',
    plazas: null,
    inscripcion: false,
  },
  {
    id: 6,
    titulo: 'Curso de Iniciación a la Pesca a Mosca',
    tipo: 'formacion',
    fecha: '2025-06-14',
    hora: '10:00',
    lugar: 'Tramo Sur — Río Lamoraña',
    descripcion: 'Taller práctico de pesca a mosca para principiantes. Se proporcionan cañas y material. Plazas muy limitadas.',
    plazas: 6,
    inscripcion: true,
  },
];

interface TipoConfig {
  emoji: string;
  label: string;
  activeClass: string;
  borderClass: string;
  badgeClass: string;
  dotClass: string;
}

const config: Record<TipoEvento, TipoConfig> = {
  pesca:     { emoji: '🎣', label: 'Día de pesca',  activeClass: 'active-pesca',     borderClass: 'border-l-blue-500',   badgeClass: 'bg-blue-50 text-blue-700 border-blue-200',   dotClass: 'bg-blue-500'   },
  limpieza:  { emoji: '🌿', label: 'Limpieza',       activeClass: 'active-limpieza',  borderClass: 'border-l-green-500',  badgeClass: 'bg-green-50 text-green-700 border-green-200', dotClass: 'bg-green-500'  },
  montaje:   { emoji: '🔧', label: 'Montaje',        activeClass: 'active-montaje',   borderClass: 'border-l-amber-500',  badgeClass: 'bg-amber-50 text-amber-700 border-amber-200', dotClass: 'bg-amber-500'  },
  reunion:   { emoji: '📋', label: 'Reunión',        activeClass: 'active-reunion',   borderClass: 'border-l-violet-500', badgeClass: 'bg-violet-50 text-violet-700 border-violet-200', dotClass: 'bg-violet-500' },
  formacion: { emoji: '📚', label: 'Formación',      activeClass: 'active-formacion', borderClass: 'border-l-rose-500',   badgeClass: 'bg-rose-50 text-rose-700 border-rose-200',   dotClass: 'bg-rose-500'   },
};

const tipos = Object.entries(config) as [TipoEvento, TipoConfig][];

function formatFecha(iso: string): string {
  const [y, m, d] = iso.split('-').map(Number);
  return new Date(y, m - 1, d).toLocaleDateString('es-ES', {
    weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
  });
}

const hoy = new Date();
const proximos = eventos.filter(e => new Date(e.fecha) >= hoy);
const pasados  = eventos.filter(e => new Date(e.fecha) <  hoy);
---

<PageLayout title="Eventos — CDF-LAMORAÑA" heading="Eventos" description="Actividades y calendario de la sociedad">
    <div class="max-w-3xl mx-auto px-6 pt-8 space-y-10">

      <!-- Filtros -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-3">Filtrar por tipo</p>
        <div id="filtros" class="flex flex-wrap gap-2">
          <button
            data-filter="all"
            class="filter-btn filter-all inline-flex items-center gap-1.5 text-sm px-4 py-2 rounded-full border font-medium transition-all duration-150 cursor-pointer bg-slate-900 text-white border-slate-900 shadow-sm"
          >
            Todos
          </button>
          {tipos.map(([tipo, cfg]) => (
            <button
              data-filter={tipo}
              class={`filter-btn inline-flex items-center gap-1.5 text-sm px-4 py-2 rounded-full border font-medium transition-all duration-150 cursor-pointer bg-white text-slate-600 border-slate-200 hover:border-slate-300`}
            >
              <span>{cfg.emoji}</span>
              {cfg.label}
            </button>
          ))}
        </div>
      </div>

      <!-- Próximos -->
      {proximos.length > 0 && (
        <section id="section-proximos">
          <h2 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-4 pb-2 border-b border-slate-200">
            Próximos eventos
          </h2>
          <div class="space-y-3">
            {proximos.map((ev) => {
              const cfg = config[ev.tipo];
              return (
                <article
                  data-tipo={ev.tipo}
                  class={`event-card bg-white rounded-2xl border border-slate-200 border-l-4 ${cfg.borderClass} shadow-sm hover:shadow-md transition-shadow overflow-hidden`}
                >
                  <div class="grid grid-cols-[160px_1fr] sm:grid-cols-[180px_1fr]">
                    <!-- Fecha -->
                    <div class="flex flex-col items-center justify-center gap-1.5 px-4 py-5 bg-slate-50 border-r border-slate-100 text-center">
                      <span class="text-3xl">{cfg.emoji}</span>
                      <time datetime={ev.fecha} class="text-xs text-slate-500 leading-snug capitalize">
                        {formatFecha(ev.fecha)}
                      </time>
                      <span class="text-xs font-bold text-slate-700 bg-slate-100 px-2 py-0.5 rounded-full">⏰ {ev.hora} h</span>
                    </div>
                    <!-- Info -->
                    <div class="p-5">
                      <div class="flex items-start justify-between gap-3 mb-1.5">
                        <h3 class="font-bold text-base text-slate-900 leading-snug">{ev.titulo}</h3>
                        <span class={`shrink-0 text-xs px-2.5 py-0.5 rounded-full border font-semibold ${cfg.badgeClass}`}>
                          {cfg.label}
                        </span>
                      </div>
                      <p class="text-xs text-slate-400 mb-3 flex items-center gap-1">
                        <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        {ev.lugar}
                      </p>
                      <p class="text-sm text-slate-600 leading-relaxed mb-3">{ev.descripcion}</p>
                      <div class="flex flex-wrap gap-2">
                        {ev.plazas !== null && (
                          <span class="text-xs bg-slate-100 text-slate-500 px-2.5 py-1 rounded-full flex items-center gap-1">
                            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                            {ev.plazas} plazas
                          </span>
                        )}
                        {ev.inscripcion && (
                          <span class="text-xs bg-blue-50 text-blue-600 border border-blue-100 px-2.5 py-1 rounded-full">
                            ✉️ Requiere inscripción
                          </span>
                        )}
                      </div>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      )}

      <!-- Pasados -->
      {pasados.length > 0 && (
        <section id="section-pasados">
          <h2 class="text-xs font-bold uppercase tracking-widest text-slate-400 mb-4 pb-2 border-b border-slate-200">
            Eventos pasados
          </h2>
          <div class="space-y-3">
            {pasados.map((ev) => {
              const cfg = config[ev.tipo];
              return (
                <article
                  data-tipo={ev.tipo}
                  class={`event-card bg-white rounded-2xl border border-slate-200 border-l-4 ${cfg.borderClass} overflow-hidden`}
                >
                  <div class="grid grid-cols-[160px_1fr] sm:grid-cols-[180px_1fr]">
                    <div class="flex flex-col items-center justify-center gap-1.5 px-4 py-5 bg-slate-50 border-r border-slate-100 text-center">
                      <span class="text-3xl grayscale">{cfg.emoji}</span>
                      <time datetime={ev.fecha} class="text-xs text-slate-500 leading-snug capitalize">
                        {formatFecha(ev.fecha)}
                      </time>
                      <span class="text-xs font-bold text-slate-500 bg-slate-100 px-2 py-0.5 rounded-full">⏰ {ev.hora} h</span>
                    </div>
                    <div class="p-5">
                      <div class="flex items-start justify-between gap-3 mb-1.5">
                        <h3 class="font-bold text-base text-slate-600 leading-snug">{ev.titulo}</h3>
                        <span class={`shrink-0 text-xs px-2.5 py-0.5 rounded-full border font-semibold ${cfg.badgeClass}`}>
                          {cfg.label}
                        </span>
                      </div>
                      <p class="text-xs text-slate-400 mb-2 flex items-center gap-1">
                        <svg class="w-3 h-3 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                        {ev.lugar}
                      </p>
                      <p class="text-sm text-slate-500 leading-relaxed">{ev.descripcion}</p>
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        </section>
      )}

      <!-- Sin resultados -->
      <p id="sin-resultados" class="hidden text-center text-slate-400 py-12 text-sm">
        No hay eventos para el tipo seleccionado.
      </p>

    </div>
</PageLayout>

<style>
  @media (max-width: 480px) {
    .event-card > div {
      grid-template-columns: 1fr !important;
    }
    .event-card > div > div:first-child {
      flex-direction: row;
      border-right: none;
      border-bottom: 1px solid #f1f5f9;
      justify-content: flex-start;
      padding: 1rem 1.25rem;
      gap: 0.75rem;
    }
  }
</style>

<script>
  const btns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.event-card');
  const sinResultados = document.getElementById('sin-resultados')!;
  const sectionProximos = document.getElementById('section-proximos');
  const sectionPasados = document.getElementById('section-pasados');

  // Colores activos por tipo
  const activeStyles: Record<string, string> = {
    all:       'bg-slate-900 text-white border-slate-900 shadow-sm',
    pesca:     'bg-blue-600 text-white border-blue-600 shadow-sm',
    limpieza:  'bg-green-600 text-white border-green-600 shadow-sm',
    montaje:   'bg-amber-500 text-white border-amber-500 shadow-sm',
    reunion:   'bg-violet-600 text-white border-violet-600 shadow-sm',
    formacion: 'bg-rose-600 text-white border-rose-600 shadow-sm',
  };
  const inactiveStyle = 'bg-white text-slate-600 border-slate-200 hover:border-slate-300';

  let active = new Set<string>();

  function applyFilter() {
    const showAll = active.size === 0;

    let visibleProximos = 0;
    let visiblePasados = 0;

    cards.forEach(card => {
      const tipo = card.dataset.tipo!;
      const visible = showAll || active.has(tipo);
      card.style.display = visible ? '' : 'none';
      const section = card.closest('section');
      if (visible && section?.id === 'section-proximos') visibleProximos++;
      if (visible && section?.id === 'section-pasados') visiblePasados++;
    });

    if (sectionProximos) sectionProximos.style.display = visibleProximos === 0 ? 'none' : '';
    if (sectionPasados)  sectionPasados.style.display  = visiblePasados  === 0 ? 'none' : '';
    sinResultados.classList.toggle('hidden', visibleProximos + visiblePasados > 0);
  }

  function updateButtons() {
    btns.forEach(btn => {
      const f = btn.dataset.filter!;
      const isActive = f === 'all' ? active.size === 0 : active.has(f);
      // Reset all classes
      btn.className = 'filter-btn inline-flex items-center gap-1.5 text-sm px-4 py-2 rounded-full border font-medium transition-all duration-150 cursor-pointer';
      btn.className += ' ' + (isActive ? activeStyles[f] : inactiveStyle);
    });
  }

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const f = btn.dataset.filter!;
      if (f === 'all') {
        active.clear();
      } else {
        if (active.has(f)) {
          active.delete(f);
        } else {
          active.add(f);
        }
      }
      updateButtons();
      applyFilter();
    });
  });
</script>
